{
  "manifest_version": 3,
  "name": "Did I Apply?",
  "key": "",
  "version": "1.0.0",
  "description": "Track your job applications across LinkedIn and justjoin.it",
  "permissions": [
    "identity",
    "activeTab",
    "storage"
  ],
  "oauth2": {
    "client_id": "836781091224-vlimqfo7gp38tq2dvgrkug46u1hdimb4.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/spreadsheets"
    ]
  },
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/jobs/*"
      ],
      "js": ["content-linkedin.js"]
    },
    {
      "matches": [
        "*://*.justjoin.it/*"
      ],
      "js": ["content-justjoinit.js"]
    }
  ]
}
